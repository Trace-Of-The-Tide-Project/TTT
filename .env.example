# Backend API root URL (no trailing slash). Used by:
# - Browser axios client (NEXT_PUBLIC_* is inlined at build time)
# - Next.js API routes under /api/auth/* (login, signup, etc.) which proxy to ${NEXT_PUBLIC_API_BASE_URL}/auth/...
#
# If unset, the app defaults to Google Cloud Run (see src/lib/public-api-base-url.ts). For local dev
# you still need a reachable backend—there is no mock auth server in this repo.
# OpenAPI: https://ttt-api-619600614028.europe-west2.run.app/api/docs
NEXT_PUBLIC_API_BASE_URL=https://ttt-api-619600614028.europe-west2.run.app

# NextAuth (only used for /api/auth/[...nextauth] wiring; app login uses custom JWT + localStorage)
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
