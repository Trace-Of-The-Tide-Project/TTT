NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000" 
NODE_ENV="development"
NEXTAUTH_SECRET="your-nextauth-secret-here"
# Backend API (NestJS on Render)

# Set to "true" once the backend ships translation groups for writers/books/
# people (see docs/backend-asks-translations.md). Lights up the per-language
# admin UI for those types. Leave unset until then.
NEXT_PUBLIC_FEATURE_EXTENDED_TRANSLATIONS="false"
